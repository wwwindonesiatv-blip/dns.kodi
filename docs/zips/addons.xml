<?xml version='1.0' encoding='UTF-8'?>
<addons>
  <addon id="script.dns.google.auto" version="1.0.0" name="Google DNS Auto" provider-name="wwwindonesiatv-blip">
    <requires>
      <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.service" library="service.py" start="startup" />
    <extension point="xbmc.addon.metadata">
      <summary lang="en">Auto Google DNS 8.8.8.8 (IPv4 + IPv6)</summary>
      <description lang="en">Otomatis ubah ke Google DNS setiap Kodi start - Tanpa pengaturan, langsung jalan! Support IPv4 + IPv6. Khusus untuk Android (Firestick, Android Box, Shield TV).</description>
      <platform>android</platform>
      <news>v1.0.0 (2025-01-21)
- Initial release
- Auto-change DNS saat Kodi start
- Support IPv4 (8.8.8.8) + IPv6 (2001:4860:4860::8888)
- Tanpa root, tanpa pengaturan
        </news>
      <assets>
        <icon>icon.png</icon>
      </assets>
    </extension>
  </addon>
  <addon id="repository.dns.google" name="Google DNS Repository" version="1.0.0" provider-name="Grok_xAI">
    <extension point="xbmc.addon.repository" name="Google DNS Repository">
      <dir>
        <info compressed="false">https://wwwindonesiatv-blip.github.io/dns.kodi/zips/addons.xml</info>
        <checksum>https://wwwindonesiatv-blip.github.io/dns.kodi/zips/addons.xml.md5</checksum>
        <datadir zip="true">https://wwwindonesiatv-blip.github.io/dns.kodi/zips/</datadir>
      </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary>Repo untuk Auto Google DNS</summary>
      <description>Repository ini menyediakan update otomatis untuk script Auto Google DNS (IPv4 &amp; IPv6) di Android.</description>
      <platform>all</platform>
      <assets>
        <icon>icon.png</icon>
        <fanart>fanart.jpg</fanart>
      </assets>
    </extension>
  </addon>
</addons>