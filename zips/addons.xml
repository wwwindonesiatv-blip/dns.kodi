<?xml version='1.0' encoding='UTF-8'?>
<addons>
    <addon id="repository.dns.kodi" name="DNS Kodi Repository" version="1.0.0" provider-name="wwwindonesiatv-blip">
        <extension point="xbmc.addon.repository" name="DNS Kodi Repository">
            <dir>
                <info compressed="false">https://raw.githubusercontent.com/wwwindonesiatv-blip/dns.kodi/main/zips/addons.xml</info>
                <checksum>https://raw.githubusercontent.com/wwwindonesiatv-blip/dns.kodi/main/zips/addons.xml.md5</checksum>
                <datadir zip="true">https://raw.githubusercontent.com/wwwindonesiatv-blip/dns.kodi/main/zips/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>Repository untuk Auto DNS Changer</summary>
            <description>Install addon Google DNS Auto langsung dari repository ini. Otomatis ubah DNS ke Google 8.8.8.8 setiap Kodi start (khusus Android).</description>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
                <fanart>fanart.jpg</fanart>
            </assets>
        </extension>
    </addon>
    <addon id="script.dns.google.auto" version="1.0.0" name="Google DNS Auto" provider-name="wwwindonesiatv-blip">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
        </requires>
        <extension point="xbmc.service" library="service.py" start="startup" />
        <extension point="xbmc.addon.metadata">
            <summary lang="en">Auto Google DNS 8.8.8.8 (IPv4 + IPv6)</summary>
            <description lang="en">Otomatis ubah ke Google DNS setiap Kodi start</description>
            <platform>android</platform>
        </extension>
    </addon>
</addons>